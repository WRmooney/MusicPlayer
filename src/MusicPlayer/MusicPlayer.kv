#:kivy 2.3.1

#:import time time

#:set bg_color 142/255.0,103/255.0,156/255.0,1
#:set btn_color 162/255.0,123/255.0,176/255.0,1
#:set dark1 132/255.0,93/255.0,146/255.0,1
#:set dark2 102/255.0,63/255.0,116/255.0,1


<MusicMenu>:
    name: 'MusicMenu'

    BoxLayout:
        orientation: 'vertical'
        size_hint: (1,1)
        # color
        canvas.before:
            Color:
                rgba:bg_color
            Rectangle:
                pos:self.pos
                size:self.size

        # back button
        AnchorLayout:
            size_hint_y: 0.1
            anchor_x: "left"
            anchor_y: "top"
            padding: [25,25,0,0]
            Button:
                id: back_screen_btn
                on_press: root.back_screen_btn()
                text: "Back"
                size_hint_y: 0.8
                size_hint_x: 0.1
                background_normal: ''
                background_color: btn_color

        # album cover
        BoxLayout:
            id: album_cover_container
            size_hint_y: 0.5
            width: self.height
            pos_hint: {'center_x' : 0.5, 'center_y' : 0.5}
            canvas.before:
                Color:
                    rgba:bg_color
                Rectangle:
                    pos:self.pos
                    size:self.size
            Image:
                size: (450,450)
                id: album_cover
                fit_mode: "contain"
                width: self.height

        # song info
        Label:
            id: song_title
            size_hint_y: 0.05
            text: "Song Title"

        Label:
            id: artist_name
            size_hint_y: 0.05
            text: "Artist"

        # song duration and bar
        BoxLayout:
            size_hint_y: 0.1
            size_hint_x: 1
            padding: [200,0,200,0]

            Label:
                id: time_stamp_label
                size_hint_x: 0.1
                text: "0:00"

            CustomSlider:
                id: duration_slider
                value_track: True
                value_track_color: 0,0,0,1
                size_hint_x: 0.8
                cursor_size: (30, 30)
                value: 0
                on_touch_up: root.slider_up()

            Label:
                id: duration_label
                size_hint_x: 0.1
                text: "0:00"

        # buttons
        BoxLayout:
            size_hint_y: 0.2
            orientation: 'horizontal'
            spacing: 100
            padding: [200,50,200,50]

            Button:
                id: shuffle_btn
                on_press: root.shuffle_queue()
                text: "shuffle"
                background_normal: ''
                background_color: btn_color
            Button:
                id: reverse_btn
                on_press: root.back_btn_press()
                text: "back"
                background_normal: ''
                background_color: btn_color
            Button:
                id: play_btn
                on_press: root.play_btn_press()
                text: "Play"
                background_normal: ''
                background_color: btn_color
            Button:
                id: forward_btn
                on_press: root.forward_btn_press()
                text: "forward"
                background_normal: ''
                background_color: btn_color
            Button:
                id: loop_btn
                on_press: root.toggle_loop()
                text: "loop: off"
                background_normal: ''
                background_color: btn_color

<Song_Row>:
    height: 100
    orientation: 'horizontal'
    Button:
        on_press: root.play_btn()
        text: 'Play'
        size_hint_x: 0.1
        size_hint_y: 0.95
        background_normal: ''
        background_color: btn_color
    Label:
        id: sr_title
        text: root.info.get('title', 'Unknown Song')
        text_size: self.size
        halign: 'left'
        valign: 'middle'
        size_hint_x: 0.4
    Label:
        id: sr_artist
        text: root.info.get('artist', 'Unknown Artist')
        size_hint_x: 0.3
    Label:
        id: sr_duration
        text: time.strftime('%M:%S', time.gmtime(root.info.get('duration', 0)))
        size_hint_x: 0.1
    Button:
        text: 'Add to Queue'
        size_hint_x: 0.1
        size_hint_y: 0.95
        background_normal: ''
        background_color: btn_color
        on_press: root.add_to_queue()

<Playlist_Row>:
    height: 100
    orientation: "horizontal"
    Button:
        text: 'Play'
        size_hint_x: 0.1
        size_hint_y: 0.95
        background_normal: ''
        background_color: btn_color
        on_press: root.play_btn()

    Label:
        id: pr_name
        text: root.name
        text_size: self.size
        halign: 'left'
        valign: 'middle'
        size_hint_x: 0.4
    Label:
        id: pr_count
        text: str(root.song_count) + ' songs'
        size_hint_x: 0.3
    Label:
        id: pr_duration
        text: time.strftime('%M:%S', time.gmtime(root.total_length))
        size_hint_x: 0.1
    Button:
        text: 'View'
        size_hint_x: 0.1
        size_hint_y: 0.95
        background_normal: ''
        background_color: btn_color
        on_press: root.view_playlist()

<MainMenu>:
    name: 'MainMenu'

    BoxLayout:
        orientation: 'vertical'
        size_hint: (1,1)

        #color
        canvas.before:
            Color:
                rgba:bg_color
            Rectangle:
                pos:self.pos
                size:self.size

        BoxLayout:
            size_hint_y: 0.2
            orientation: 'horizontal'

            ToggleButton:
                size_hint_x: 0.5
                text: 'Songs'
                group: 'mainmenutabs'
                allow_no_selection: False
                on_press: root.songs_tab_btn()
                background_normal: ''
                background_down: ''
                background_color: dark1 if self.state == 'normal' else dark2

            ToggleButton:
                size_hint_x: 0.5
                text: 'Playlists'
                group: 'mainmenutabs'
                state: 'down'
                allow_no_selection: False
                on_press: root.playlists_tab_btn()
                background_normal: ''
                background_down: ''
                background_color: dark1 if self.state == 'normal' else dark2

        RecycleView:
            id: main_song_list
            size_hint_y: 0.7
            do_scroll_x: False
            do_scroll_y: True
            viewclass: 'Playlist_Row'
            RecycleBoxLayout:
                default_size: None, dp(48)
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: 'vertical'

        BoxLayout:
            size_hint_y: 0.1
            orientation: 'horizontal'

            Button:
                id: open_music_menu_btn
                on_press: root.open_music_menu()
                size_hint_x: 0.1
                text: 'Back'
                background_normal: ''
                background_color: dark1

            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.4
                Label:
                    id: cur_title_label
                    text: "No Song Info"
                    size_hint_y: 0.5
                    canvas.before:
                        Color:
                            rgba:dark1
                        Rectangle:
                            pos:self.pos
                            size:self.size
                Label:
                    id: cur_artist_label
                    text: "No Artist Info"
                    size_hint_y: 0.5
                    canvas.before:
                        Color:
                            rgba:dark1
                        Rectangle:
                            pos:self.pos
                            size:self.size

            Label:
                id: cur_duration_label
                text: '0:00/0:00'
                size_hint_x: 0.2
                canvas.before:
                    Color:
                        rgba:dark1
                    Rectangle:
                        pos:self.pos
                        size:self.size


            Button:
                id: main_back_btn
                on_press: root.back_btn_press()
                size_hint_x: 0.1
                text: '<<'
                background_normal: ''
                background_color: dark1

            Button:
                id: main_play_btn
                on_press: root.play_btn_press()
                size_hint_x: 0.1
                text: 'Play'
                background_normal: ''
                background_color: dark1

            Button:
                id: main_skip_btn
                on_press: root.skip_btn_press()
                size_hint_x: 0.1
                text: '>>'
                background_normal: ''
                background_color: dark1

<PlaylistView>:
    name: 'PlaylistView'

    BoxLayout:
        orientation: 'vertical'
        size_hint: (1,1)

        #color
        canvas.before:
            Color:
                rgba:bg_color
            Rectangle:
                pos:self.pos
                size:self.size

        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: 0.3

        RecycleView:
            id: song_list
            size_hint_y: 0.5
            do_scroll_x: False
            do_scroll_y: True
            viewclass: 'Song_Row'
            RecycleBoxLayout:
                default_size: None, dp(48)
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: 'vertical'


        BoxLayout:
            size_hint_y: 0.1
            orientation: 'horizontal'

            Button:
                id: open_music_menu_btn
                on_press: root.open_music_menu()
                size_hint_x: 0.1
                text: 'Back'
                background_normal: ''
                background_color: dark1

            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.4
                Label:
                    id: cur_title_label
                    text: "No Song Info"
                    size_hint_y: 0.5
                    canvas.before:
                        Color:
                            rgba:dark1
                        Rectangle:
                            pos:self.pos
                            size:self.size
                Label:
                    id: cur_artist_label
                    text: "No Artist Info"
                    size_hint_y: 0.5
                    canvas.before:
                        Color:
                            rgba:dark1
                        Rectangle:
                            pos:self.pos
                            size:self.size

            Label:
                id: cur_duration_label
                text: '0:00/0:00'
                size_hint_x: 0.2
                canvas.before:
                    Color:
                        rgba:dark1
                    Rectangle:
                        pos:self.pos
                        size:self.size


            Button:
                id: main_back_btn
                on_press: root.back_btn_press()
                size_hint_x: 0.1
                text: '<<'
                background_normal: ''
                background_color: dark1

            Button:
                id: main_play_btn
                on_press: root.play_btn_press()
                size_hint_x: 0.1
                text: 'Play'
                background_normal: ''
                background_color: dark1

            Button:
                id: main_skip_btn
                on_press: root.skip_btn_press()
                size_hint_x: 0.1
                text: '>>'
                background_normal: ''
                background_color: dark1
